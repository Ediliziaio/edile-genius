# ============================================================
# Edile Genius — Environment Variables
# ============================================================
# These are PUBLIC / PUBLISHABLE keys used by the Vite frontend.
# They are safe to commit and are NOT secrets.
#
# Private secrets (ElevenLabs API key, service role key, etc.)
# are stored as Supabase Edge Function Secrets and are NEVER
# exposed to the client.
# ============================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
VITE_SUPABASE_PROJECT_ID=your-project-id
